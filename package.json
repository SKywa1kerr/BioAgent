{
  "name": "ultimate-bioagent",
  "private": true,
  "version": "0.1.0",
  "description": "Ultimate BioAgent desktop app",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently -k \"vite\" \"electron .\"",
    "electron:build": "npm run build && electron-builder",
    "build:all": "npm run electron:build",
    "test:js": "node --test \"tests/test_*.mjs\"",
    "test:py": "pytest tests",
    "test": "npm run test:js && npm run test:py"
  },
  "dependencies": {
    "@tanstack/react-virtual": "^3.13.24",
    "framer-motion": "^11.11.11",
    "openai": "^4.104.0",
    "pdfmake": "^0.3.7",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.0.0",
    "concurrently": "^9.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0"
  },
  "build": {
    "appId": "com.bioagent.desktop",
    "productName": "UltimateBioAgent",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "extraResources": [
      {
        "from": "dist-python/bioagent-sidecar/",
        "to": "sidecar/bioagent-sidecar",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "signAndEditExecutable": false
    }
  }
}
