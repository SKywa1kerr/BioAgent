# LLM API 配置（必填）
# 支持任何 OpenAI 兼容的 API 服务
LLM_API_KEY=
LLM_BASE_URL=https://models.sjtu.edu.cn/api/v1
# LLM_API_FORMAT=openai  (默认即 openai，无需显式设置)

# ── 配置示例 ──────────────────────────────────────────────
#
# 方式一：ChatAnywhere（推荐国内用户，免费，国内直连无需翻墙）
#   1. 前往 https://github.com/chatanywhere/GPT_API_free 领取免费 API Key
#   2. 填写如下：
#   LLM_API_KEY=sk-xxxxxxx
#   LLM_BASE_URL=https://api.chatanywhere.tech/v1
#   3. 运行时指定模型，例如：python run.py --dataset base --model gpt-4.1-mini
#   免费额度：200次/天，支持 gpt-4.1 / gpt-4.1-mini / deepseek-chat 等
#
# 方式二：OpenRouter（推荐国外用户，有免费模型可用）
#   1. 注册 https://openrouter.ai 获取 API Key
#   2. 填写如下：
#   LLM_API_KEY=sk-or-v1-xxxxxxx
#   LLM_BASE_URL=https://openrouter.ai/api/v1
#   3. 运行时使用免费模型：python run.py --dataset base --model google/gemma-3-27b-it:free
#
# 方式三：DeepSeek 官方
#   LLM_API_KEY=sk-xxxxxxx
#   LLM_BASE_URL=https://api.deepseek.com/v1
#
# 方式四：其他 OpenAI 兼容服务（Anthropic 中转站等）
#   LLM_API_KEY=sk-xxxxxxx
#   LLM_BASE_URL=https://your-proxy.com/v1
