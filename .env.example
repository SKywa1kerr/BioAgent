# LLM API 配置（必填）
# 复制此文件为 .env 并填入你的 API Key
# cp .env.example .env

# 方式一：ChatAnywhere（推荐国内用户，免费，国内直连）
# 领取地址：https://github.com/chatanywhere/GPT_API_free
LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LLM_BASE_URL=https://api.chatanywhere.tech/v1

# 方式二：OpenRouter（推荐国外用户）
# LLM_API_KEY=sk-or-v1-xxxxxxx
# LLM_BASE_URL=https://openrouter.ai/api/v1

# 方式三：DeepSeek 官方
# LLM_API_KEY=sk-xxxxxxx
# LLM_BASE_URL=https://api.deepseek.com/v1
